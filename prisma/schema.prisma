// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}



model PkkService {
  id                      Int      @id @default(autoincrement())
  nomor_pkk               String   @unique // PKK Number [cite: 54]
  nama_kapal              String   // Vessel Name [cite: 54]
  call_sign               String   // Call Sign [cite: 54]
  tanda_pendaftaran_kapal String   // Ship Registry No [cite: 54]
  tanggal_eta             DateTime // ETA DateTime [cite: 54]
  tanggal_etd             DateTime // ETD DateTime [cite: 54]
  jenis_trayek            String   // jenis_trayek [cite: 54]
  timestamp               DateTime @default(now()) // API Timestamp [cite: 54]

  @@map("pkk_services")
}


// 2. Transportation Service (BSIMS to N4)

model TransportationService {
  id               Int      @id @default(autoincrement())
  no_kendaraan     String   // Vehicle Number [cite: 55]
  nama_perusahaan  String   // Company Name [cite: 55]
  nama_perorangan  String   // Driver/Owner Name [cite: 55]
  available        String   // available status [cite: 55]
  masa_expired     DateTime // Permit Expiry Date [cite: 55]
  timestamp        DateTime @default(now()) // API Timestamp [cite: 55]

  @@map("transportation_services")
}


// 3. SPPB Service (BSIMS to N4)
model SppbService {
  id              Int      @id @default(autoincrement())
  nomor_sppb      String   @unique // SPPB Number [cite: 61]
  tanggal_sppb    DateTime // SPPB Date [cite: 61]
  nomor_kontainer String   // Container Number [cite: 61]
  nomor_bl        String   // Bill of Lading Number [cite: 61]
  timestamp       DateTime @default(now()) // Current API Timestamp [cite: 61]

  @@map("sppb_services")
}


// 4. SP2 Service (N4 to BSIMS)

model Sp2Service {
  id                     Int       @id @default(autoincrement())
  ref_number             String    @unique // Reference Number
  nomor_sp2              String    // SP2 Number
  nomor_do_pelayaran     String?   // Shipping Line DO
  nomor_kontainer        String    // Container Number
  nomor_bl               String?   // Bill of Lading No
  iso_code               String?   // Container ISO Code
  pemilik_kontainer      String?   // Container Owner
  nama_penerima          String?   // Consignee Name
  npwp_penerima          String?   // Consignee Tax ID
  perusahaan_trucking    String?   // Trucking Company
  stid_truk              String?   // STID Number
  nopol_truk             String?   // Truck Plate Number
  nama_supir             String?   // Driver Name
  pin_gate               String    // Gate Pass PIN
  tgl_awal_berlaku       DateTime? // Valid From
  tgl_akhir_berlaku      DateTime? // Valid Until
  batas_waktu_storage    DateTime? // Storage Paid Until
  nomor_sppb             String?   // SPPB Number
  status_segel_bc        String?   // BC Seal Status
  status_admin_pelayaran String?   // Shipping Admin Status
  status_uang_jaminan    String?   // Deposit Status
  status_storage         String?   // Storage Status
  depo_pengembalian      String?   // Return Depot
  jenis_pengeluaran      String?   // Release Type
  lokasi_kontainer       String?   // Container Location
  status_hold            String?   // Hold Status
  status_gate            String?   // Gate Status
  created_at             DateTime  @default(now()) // Record Creation Date
  updated_at             DateTime  @updatedAt // Record Last Update Date
  timestamp              DateTime  @default(now()) // Current API Timestamp

  @@map("sp2_services")
}

// 5. CODECO SERVICE (N4 to BSIMS)
// Container Discharge/Loading Order
model CodecoService {
  id                 Int       @id @default(autoincrement())

  // Identitas Transaksi & Gate
  ref_number         String    @unique // Ref Number (unique)
  id_gatepass        String    // Gatepass id
  transportation_id  String    // Transportation id
  no_kendaraan       String    // Vehicle number
  car                String?   // Car
  spj_no             String?   // Spj number
  spj_date           DateTime? // Spj date
  gate_in            DateTime? // Gate in
  gate_out           DateTime? // Gate out

  // Transaksi & Kategori
  category           String    // Category
  kd_transaksi       String    // Transaction code

  // Data Kontainer (Container Details)
  no_cont            String    // Container number
  uk_cont            String    // Container size
  jns_cont           String    // Container type
  fl_cont_kosong     String?   // Container empty flag
  no_segel_bc        String?   // BC seal number

  // Data Dokumen
  no_dok_inout       String?   // Dok inout number
  tgl_dok_inout      DateTime? // Dok inout date
  no_bc11            String?   // BC11 number
  tgl_bc11           DateTime? // BC11 date
  no_bl_awb          String?   // BL/AWB number

  // Data Fisik & Lokasi
  bruto              Float?    // Bruto weight
  id_consignee       String?   // Consignee id
  consignee          String?   // Consignee name
  kd_pelabuhan       String?   // Port code
  kd_gudang          String?   // Warehouse code
  kd_tps             String?   // TPS code
  kd_status          String?   // Status code (1=Bongkar, 2=Muat, 3=Keluar, 4=Masuk)

  // Metadata
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  @@map("codeco_services")
}

// 6. COARRI SERVICE (N4 to BSIMS)
// Container Arrival Notice
model CoarriService {
  id                 Int       @id @default(autoincrement())

  // Identitas Referensi
  ref_number         String    @unique // Ref number (unique)

  // Data Transportasi
  nm_angkut          String?   // Vessel/Transport name
  call_sign          String?   // Call sign
  no_voy_flight      String?   // Voyage/Flight number
  kd_pbm             String?   // PBM code

  // Data Jumlah
  jml_total          Int?      // Total amount
  jml_out            Int?      // Out amount

  // Transaksi & Kategori
  category           String    // Category
  kd_transaksi       String    // Transaction code

  // Data Kontainer (Container Details)
  no_cont            String    // Container number
  uk_cont            String    // Container size
  jns_cont           String    // Container type
  fl_cont_kosong     String?   // Container empty flag
  no_segel_bc        String?   // BC seal number

  // Data Dokumen
  no_dok_inout       String?   // Dok inout number
  tgl_dok_inout      DateTime? // Dok inout date
  no_bc11            String?   // BC11 number
  tgl_bc11           DateTime? // BC11 date
  no_bl_awb          String?   // BL/AWB number

  // Data Fisik & Lokasi
  bruto              Float?    // Bruto weight
  id_consignee       String?   // Consignee id
  consignee          String?   // Consignee name
  kd_pelabuhan       String?   // Port code
  kd_gudang          String?   // Warehouse code
  kd_tps             String?   // TPS code
  kd_status          String?   // Status code (1=Bongkar, 2=Muat, 3=Keluar, 4=Masuk)

  // Metadata
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  @@map("coarri_services")
}

// 7. REALISASI TAMBAT (N4 to BSIMS)
model RealisasiTambat {
  id                  Int      @id @default(autoincrement())
  nomor_pkk           String   // PKK reference number
  nomor_ppk           String   // PPK reference number
  no_ppkb_tambat      String   // Berthing PPKB number
  tgl_mulai_tambat    DateTime // Berthing start date & time
  tgl_selesai_tambat  DateTime // Berthing end date & time
  dermaga             String   // Berth name
  gt                  Float    // Gross tonnage
  biaya               Float    // Total cost
  nomor_pkk_tugboat   String?  // Tugboat PKK number (optional)
  timestamp           DateTime @default(now()) // Record timestamp

  @@map("realisasi_tambat")
}

// 8. RPKRO (N4 to BSIMS)
model RpkroService {
  id                     Int      @id @default(autoincrement())
  nomor_rpkro            String   @unique // RPKRO reference number
  nomor_ppk              String   // PPK reference number
  nomor_ppkb             String   // PPKB reference number
  nomor_layanan          String   // Service number
  kode_dermaga           String   // Berth code
  tanggal_rencana        DateTime // Planned date & time
  npkb_nomor             String   // NPKB number
  nomor_rkbm_muat        String   // RKBM Loading number
  nomor_rkbm_bongkar     String   // RKBM Discharge number
  kegiatan_bongkar       String   // Discharge activity
  kegiatan_muat          String   // Loading activity
  komoditi               String?  // Commodity type (optional)
  nomor_gudang           String?  // Warehouse number (optional)
  keterangan             String?  // Notes (optional)
  tanggal_mulai_tambat   DateTime // Start berthing date & time
  tanggal_selesai_tambat DateTime // End berthing date & time
  kade_meter_awal        Float    // Start kade meter
  kade_meter_akhir       Float    // End kade meter
  timestamp              DateTime @default(now()) // Record timestamp

  @@map("rpkro_services")
}

// 9. SUBMIT MANIFEST (BSIMS – N4)
model SubmitManifest {
  id          Int      @id @default(autoincrement())
  no_bl_awb   String   // Bill of Lading Air Waybill Number [cite: 60]
  tgl_bl_awb  DateTime // BL Air Waybill Date [cite: 60]
  consignee   String   // Consignee [cite: 60]
  bruto       Float    // Gross Weight (KGS) [cite: 60]
  no_cont     String   // Container Number [cite: 60]
  uk_cont     String   // Container Size [cite: 60]
  timestamp   DateTime @default(now()) // Current API Timestamp [cite: 60]

  @@map("submit_manifests")
}

// 10. NPE (BSIMS to N4)
model NpeService {
  id             Int      @id @default(autoincrement())
  no_npe         String   @unique // NPE Number [cite: 62]
  tg_npe         DateTime // NPE Date [cite: 62]
  no_peb         String   // PEB Number [cite: 62]
  no_cont        String   // Container Number [cite: 62]
  size           String   // Container Size [cite: 62]
  nama_kapal     String   // Vessel Name [cite: 62]
  no_voy_flight  String   // Voyage Number [cite: 62]
  timestamp      DateTime @default(now()) // Current API Timestamp [cite: 62]

  @@map("npe_services")
}